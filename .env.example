# ============================================================
# .env (Environment Settings)
# ============================================================
# Environment settings for this project.
#
# IMPORTANT: Copy .env.example to .env before running Python.
#
# Required file names:
#
#   .env.example (committed, any secrets must be sanitized)
#   .env (local copy, can hold secrets, listed in .gitignore)
#
# Professional projects may use .env for authentication,
# tokens, passwords, or connection details for protected infrastructure.

# === Kafka broker ===

# Local Kafka usually runs at localhost:9092 or 127.0.0.1:9092
# First, try localhost:9092.
# If that doesn't work, try 127.0.0.1:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Specify the address family for the Kafka broker connection.
# Options: any (default), v4, v6
# Uncomment and set to v6 only if you are on Windows with WSL2
# and localhost resolves to ::1 instead of 127.0.0.1.
KAFKA_BROKER_ADDRESS_FAMILY=v6

# === Kafka topic ===

# This project exchanges messages on this topic.
KAFKA_TOPIC=streaming-06-scenarios-case

# Delete and recreate the topic each time the producer starts.
# This ensures a clean topic for every run.
# Useful while learning.
# Set to false in production to preserve existing messages.
# Default is true.
KAFKA_CLEAR_TOPIC_ON_START=true

# === Producer settings ===

# Number of messages to produce before stopping.
# Default is 3 messages.
PRODUCER_MESSAGE_COUNT=3

# Seconds to wait between produced messages.
# Default is 2 seconds.
PRODUCER_MESSAGE_INTERVAL_SECONDS=2

# Maximum number of messages to produce before stopping.
# This prevents the producer from running indefinitely and
# filling your drive with log files.
# Increase this if you want a longer run. Default: 50.
PRODUCER_MAX_MESSAGES=50

# OPTIONAL:
# How often to poll a service for new readings (seconds).
# Do not set below 10.
# Many sites rate-limit frequent requests.
# Be polite to public data sources.
PRODUCER_POLL_INTERVAL_SECONDS=15

# === Consumer settings ===

# Consumers must be assigned a consumer group.
# As the volume of messages increases,
# more consumers may be added to the same consumer group
# to share the load of processing messages.
KAFKA_GROUP_ID=streaming-consumer-group-A

# Specify where the consumer should begin reading.
# Options include:
#   earliest (from the beginning of the topic),
#   latest (only new messages) and
#   none (error if no offsets).
KAFKA_AUTO_OFFSET_RESET=earliest

# When the consumer reaches the end of the topic,
# it will wait this many seconds before stopping
# if no new messages arrive.
# Default is 10 seconds.
CONSUMER_TIMEOUT_SECONDS=10

# Optional upper bound on messages consumed in one run.
# The consumer will also stop automatically when no new messages
# arrive within CONSUMER_TIMEOUT_SECONDS; whichever comes first.
# Set high to let the timeout drive all stops.
CONSUMER_MAX_MESSAGES=1000
